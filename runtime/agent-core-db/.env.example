# Local Agent Core DB runtime.
# Canonical production source: Infisical/runtime env injection. Do not commit real secrets.
AGENT_CORE_DB_ENABLED=true
AGENT_DB_CONTAINER=agent-postgres
AGENT_DB_ADMIN_USER=agent_admin
AGENT_DB_ADMIN_PASSWORD=replace-with-infisical-secret
AGENT_DB_HOST_BIND=127.0.0.1
AGENT_DB_HOST_PORT=55430
AGENT_DB_NAME=zeus_agent
AGENT_CALENDAR_DB_NAME=nettu_calendar
AGENT_CRM_DB_NAME=zeus_agent

# Runtime roles created/rotated by scripts/agent_core_roles.py.
AGENT_DB_RUNTIME_USER=agent_runtime
AGENT_DB_RUNTIME_PASSWORD=replace-with-infisical-secret
FACTORY_DB_RUNTIME_USER=factory_runtime
FACTORY_DB_RUNTIME_PASSWORD=replace-with-infisical-secret
CALENDAR_DB_RUNTIME_USER=calendar_runtime
CALENDAR_DB_RUNTIME_PASSWORD=replace-with-infisical-secret
CRM_DB_RUNTIME_USER=crm_runtime
CRM_DB_RUNTIME_PASSWORD=replace-with-infisical-secret
SALES_DB_RUNTIME_USER=sales_runtime
SALES_DB_RUNTIME_PASSWORD=replace-with-infisical-secret
ACCOUNTING_DB_RUNTIME_USER=accounting_runtime
ACCOUNTING_DB_RUNTIME_PASSWORD=replace-with-infisical-secret
FITNESS_DB_RUNTIME_USER=fitness_runtime
FITNESS_DB_RUNTIME_PASSWORD=replace-with-infisical-secret
AGENT_MANAGEMENT_DB_RUNTIME_USER=agent_management_runtime
AGENT_MANAGEMENT_DB_RUNTIME_PASSWORD=replace-with-infisical-secret

# Canonical connection strings for host tools that can connect over TCP.
AGENT_DATABASE_URL=postgresql://agent_runtime:***@127.0.0.1:55430/zeus_agent
FACTORY_DATABASE_URL=postgresql://factory_runtime:***@127.0.0.1:55430/zeus_agent
CALENDAR_DATABASE_URL=postgresql://calendar_runtime:***@127.0.0.1:55430/nettu_calendar
CRM_DATABASE_URL=postgresql://crm_runtime:***@127.0.0.1:55430/zeus_agent
SALES_DATABASE_URL=postgresql://sales_runtime:***@127.0.0.1:55430/zeus_agent
ACCOUNTING_DATABASE_URL=postgresql://accounting_runtime:***@127.0.0.1:55430/zeus_agent
FITNESS_DATABASE_URL=postgresql://fitness_runtime:***@127.0.0.1:55430/zeus_agent
AGENT_MANAGEMENT_DATABASE_URL=postgresql://agent_management_runtime:***@127.0.0.1:55430/zeus_agent

# Docker-network URLs are derived by scripts/zeus-sync-secrets.sh for sidecars.
AGENT_DATABASE_URL_DOCKER=postgresql://agent_runtime:***@agent-postgres:5432/zeus_agent
FACTORY_DATABASE_URL_DOCKER=postgresql://factory_runtime:***@agent-postgres:5432/zeus_agent
CALENDAR_DATABASE_URL_DOCKER=postgresql://calendar_runtime:***@agent-postgres:5432/nettu_calendar
CRM_DATABASE_URL_DOCKER=postgresql://crm_runtime:***@agent-postgres:5432/zeus_agent
SALES_DATABASE_URL_DOCKER=postgresql://sales_runtime:***@agent-postgres:5432/zeus_agent
ACCOUNTING_DATABASE_URL_DOCKER=postgresql://accounting_runtime:***@agent-postgres:5432/zeus_agent
FITNESS_DATABASE_URL_DOCKER=postgresql://fitness_runtime:***@agent-postgres:5432/zeus_agent
AGENT_MANAGEMENT_DATABASE_URL_DOCKER=postgresql://agent_management_runtime:***@agent-postgres:5432/zeus_agent
